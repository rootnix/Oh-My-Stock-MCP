STOCK_MCP_DATA_DIR=.data
BROWSER_HEADLESS=true
BROWSER_CHANNEL=
BROWSER_EXECUTABLE_PATH=
BROWSER_TIMEZONE_ID=Asia/Seoul

# Recommended: keep credentials empty and store a browser session instead.
SAMSUNGPOP_AUTH_MODE=manual_session
SHINHANSEC_AUTH_MODE=manual_session
MIRAEASSET_AUTH_MODE=manual_session
NHSEC_AUTH_MODE=manual_session

# Optional credential mode
SAMSUNGPOP_USER_ID=
SAMSUNGPOP_USER_PASSWORD=
SAMSUNGPOP_ACCOUNT_PASSWORD=
SAMSUNGPOP_ACCOUNT_NUMBER_HINT=

# ShinhanSec supports automatic ID login. Add the optional 4-digit account password
# if you want to unlock password-protected balance/transaction pages later.
SHINHANSEC_USER_ID=
SHINHANSEC_USER_PASSWORD=
SHINHANSEC_ACCOUNT_PASSWORD=

# Mirae Asset Securities supports automatic ID(조회용) login.
MIRAEASSET_USER_ID=
MIRAEASSET_USER_PASSWORD=

# NH투자증권 supports automatic 조회전용(ID) login.
NHSEC_USER_ID=
NHSEC_USER_PASSWORD=
